rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny-all fallback
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, create, update, delete: if (
        request.auth != null
        && request.auth.uid == userId
      ) || (
        request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /public_announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /tickets/{ticketId} {
      // Visible to all signed-in users (shared live queue)
      allow read: if request.auth != null;

      // Ticket can only be created by the authenticated author
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Owner or admin can update/delete
      allow update, delete: if (
        request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ) || (
        request.auth != null
        && resource.data.authorId == request.auth.uid
      );
    }
  }
}
